TELEGRAM_TOKEN=your_telegram_bot_token_here
OPENAI_API_KEY=your_openai_api_key_here
AIRTABLE_API_KEY=your_airtable_personal_access_token_here
AIRTABLE_BASE_ID=your_airtable_base_id_here
SERPAPI_KEY=your_serpapi_key_here

# ID канала для мониторинга (например -1001234567890). Оставь 0 — принимать из любого канала.
CHANNEL_ID=0
# Куда слать результаты из канала: ID личного чата с владельцем или группы менеджеров.
REPORT_CHAT_ID=0

# Токен ОСНОВНОГО бота (для отправки совпадений в чаты клиентов)
MAIN_BOT_TOKEN=your_main_bot_token_here
# Путь к SQLite-базе основного бота (для поиска group_chat_id по client_tag)
MAIN_DB_PATH=/opt/telegram-bot/bot_database.db
